# Git-champ API (required for auth)
VITE_API_BASE_URL=http://localhost:8080

# Google OAuth (optional — required for "Continue with Google")
# Redirect URI must match Google Console and server GOOGLE_REDIRECT_URL (dev: http://localhost:3000/auth/callback — see vite.config server.port)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=
